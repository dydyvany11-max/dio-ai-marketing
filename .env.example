GIGACHAT_AUTHORIZATION_KEY=your_gigachat_authorization_key_or_full_basic_header
GIGACHAT_CLIENT_ID=your_gigachat_client_id
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_VERIFY_SSL_CERTS=false
VK_AI_PROVIDER=auto
# Yandex GPT auth (any one of API key options + model URI)
YANDEX_GPT_API_KEY=
YANDEX_GPT_IAM_TOKEN=
YANDEX_GPT_MODEL_URI=
YANDEX_GPT_MODEL_NAME=yandexgpt-5-lite
YANDEX_GPT_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_GPT_TIMEOUT_SEC=60
# Compatibility aliases (if you already have Yandex Cloud vars from AI Studio)
YANDEX_CLOUD_FOLDER_ID=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_ACCESS_KEY_ID=
YANDEX_CLOUD_SECRET_ACCESS_KEY=
# Token usage cost estimation (per 1000 tokens)
AI_USAGE_CURRENCY=RUB
GIGACHAT_PRICE_INPUT_PER_1K=0
GIGACHAT_PRICE_OUTPUT_PER_1K=0
YANDEX_GPT_PRICE_INPUT_PER_1K=0
YANDEX_GPT_PRICE_OUTPUT_PER_1K=0
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
POSTGRES_DB=dio_ai_marketing
POSTGRES_USER=dio
POSTGRES_PASSWORD=dio_password
POSTGRES_PORT=5432
VK_APP_ID=1234567
VK_APP_SECRET=your_vk_app_secret
VK_REDIRECT_URI=https://your-domain.com/vk/callback
VK_API_VERSION=5.199
VK_TOKEN_PATH=vk_token.json
VK_GROUP_TOKEN=
VK_GROUP_ID=
VK_BROWSER_PROFILE_DIR=db/vk_browser_profile
TRENDS_DB_PATH=db/trends.db
TRENDS_WINDOW_HOURS=6
TRENDS_MAX_TERMS=50
# Keep disabled for speed: per-token online translation is expensive
TRENDS_TRANSLATE_EN=false
TRENDS_MAX_TOKENS_PER_DOC=400
NEWSAPI_KEY=
NEWSAPI_SOURCES=
GDELT_QUERY=
VKID_APP_ID=1234567
VKID_REDIRECT_URI=https://your-domain.com/vkid/callback
VKID_DOMAIN=id.vk.ru
VKID_SCOPE=vkid.personal_info
VKID_TOKEN_PATH=vkid_token.json
VK_VECTOR_RAG_ENABLED=true
RAG_EMBEDDINGS_BACKEND=auto
RAG_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDINGS_DEVICE=cpu
RAG_EMBEDDINGS_URL=
HUGGINGFACE_SPACE_URL=
RAG_EMBEDDINGS_TIMEOUT_SEC=60
RAG_EMBEDDINGS_BATCH_SIZE=16
RAG_CHROMA_PATH=db/vk_rag_chroma
